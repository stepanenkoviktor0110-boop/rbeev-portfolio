DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
AUTH_SECRET="replace_with_a_long_random_secret_min_16_chars"
ADMIN_PASSWORD="replace_with_initial_admin_password_min_8_chars"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# OAuth-токен вашего Яндекс.Диска (получить на oauth.yandex.ru)
YANDEX_DISK_TOKEN="your_yandex_oauth_token"

# Папка для прямых загрузок файлов (без схемы disk:, просто /путь)
# Используется только при загрузке файлов через форму в админке.
# При импорте папки по ссылке файлы НЕ копируются — используется ваша папка напрямую.
YANDEX_DISK_BASE_DIR="/site-gallery"
